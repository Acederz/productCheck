# Flask
FLASK_ENV=production
SECRET_KEY=请换成随机长字符串
JWT_SECRET_KEY=请换成另一段随机长字符串

# MySQL 8.0
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=product_admin
MYSQL_PASSWORD=请填写强密码
MYSQL_DATABASE=product_check

# 默认管理员（仅首次 init-db 时创建，之后请尽快改密）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请填写强密码

# 文件存储目录（相对 backend 目录，生产建议用绝对路径也可）
STORAGE_PATH=../storage
