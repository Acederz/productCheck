# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-in-production

# MySQL 8.0
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=product_check

# 默认管理员（首次 init-db 时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 文件存储目录（相对 backend 目录）
STORAGE_PATH=../storage

# 生产部署请参考 deploy/env.production.example
# 并将 FLASK_ENV 改为 production，同时更换 SECRET_KEY / JWT_SECRET_KEY
